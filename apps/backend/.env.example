# FastAPI backend environment
# Copy to .env and fill with real values.
# For Railway deployment, set these in the Railway dashboard (Variables tab).

# ─── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-publishable-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Optional: for future local JWT verification (currently unused)
# SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-api-settings

# ─── Gemini ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ─── 법령정보센터 API ─────────────────────────────────────────────────────
LAW_API_OC=your-law-api-oc-here

# ─── Admin endpoints ──────────────────────────────────────────────────────
# Separate secret for /admin/rag/sync. Generate with: openssl rand -hex 32
LAW_SYNC_SECRET=your-admin-sync-secret-here

# ─── Runtime ───────────────────────────────────────────────────────────────
# development | production
# production mode enforces CORS origins, hides exception details.
ENVIRONMENT=development

# Comma-separated list. In production this is REQUIRED (app fails to start otherwise).
# Example for mobile app only (Expo Web, or testing): include app domain(s).
# Example for landing page: https://lawos.kr,https://www.lawos.kr
BACKEND_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:3000,http://127.0.0.1:3000

# ─── Railway reserved ─────────────────────────────────────────────────────
# PORT is auto-provided by Railway; Dockerfile uses it via --port $PORT
