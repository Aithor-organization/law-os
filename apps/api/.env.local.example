# LAW.OS Backend API — environment template
# Copy to `.env.local` and fill in real values.
# `.env.local` is gitignored — NEVER commit real keys.
#
# ============================================================================
# Supabase
# ============================================================================
# NOTE: For local `supabase functions serve`, names beginning with `SUPABASE_`
# are reserved by the CLI/runtime and may be skipped. Use LAWOS_* locally.
# The function code falls back to SUPABASE_* for deployed environments.

# Project URL — public, same as mobile app
LAWOS_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# 🔴 service_role key — BYPASSES RLS. Backend only. NEVER ship to mobile/web client.
# Where: Supabase Dashboard → Settings → API → Project API keys → service_role
LAWOS_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# anon key — used for validating user JWTs (public, safe)
LAWOS_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================================
# Google Gemini (single provider: chat + embeddings)
# ============================================================================
# Where: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Model IDs (override here if Google releases newer models)
# Chat — fast/cheap tier (most user questions)
GEMINI_MODEL_FLASH=gemini-2.5-flash
# Chat — high-quality tier (Deep Debate, complex reasoning)
GEMINI_MODEL_PRO=gemini-2.5-pro
# Embeddings (3072-dim via Matryoshka — matches statutes.embedding schema)
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
