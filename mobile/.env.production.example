# LAW.OS Mobile — Production environment template
# Used by EAS Build for `production` and `preview` profiles.
# Copy to .env.production and fill, OR set via `eas secret` for the project.

# Backend (Railway deployment)
EXPO_PUBLIC_API_BASE_URL=https://api.lawos.kr

# Supabase (same project as backend — URL and anon key are public-safe)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key-here

# NEVER include:
# - SUPABASE_SERVICE_ROLE_KEY (server-side only)
# - GEMINI_API_KEY (server-side only)
# - LAW_SYNC_SECRET (server-side only)
