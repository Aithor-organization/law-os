{
  "expo": {
    "name": "LAW.OS",
    "slug": "law-os",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lawos",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "kr.lawos.app",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "판례 사진 등을 기록할 때 카메라에 접근합니다. 사용하지 않으면 거부하셔도 무방합니다.",
        "NSPhotoLibraryUsageDescription": "판례 사진을 저장하거나 불러올 때 사진 접근 권한이 필요합니다. 사용하지 않으면 거부하셔도 무방합니다.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "kr.lawos.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#A855F7",
          "defaultChannel": "default"
        }
      ]
    ],
    "_comment_sentry_plugin": "Sentry plugin (@sentry/react-native/expo) should be re-added once SENTRY_AUTH_TOKEN is provisioned via eas env:create. Enabling it without the token causes 'Auth token is required' during :app:createBundleReleaseJsAndAssets_SentryUpload gradle task. See docs/deployment.md §3.",
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "3da755bb-da5f-47fe-b265-30da2604b01f"
      }
    },
    "owner": "sioxgap409",
    "updates": {
      "url": "https://u.expo.dev/3da755bb-da5f-47fe-b265-30da2604b01f"
    }
  }
}
