# LAW.OS Mobile — Environment template
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — NEVER commit real keys.
#
# Where to get these:
# Supabase Dashboard → Settings → API
#   - Project URL          → EXPO_PUBLIC_SUPABASE_URL
#   - Project API keys → anon (publishable) → EXPO_PUBLIC_SUPABASE_ANON_KEY
#
# DO NOT put the `service_role` key here. That key bypasses RLS and belongs
# only on the backend (Cloudflare Workers secrets), never in the mobile app.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key-here

# Preferred chat backend (FastAPI)
# Example: http://127.0.0.1:8000
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Sentry error monitoring (optional for local dev)
# Leave empty to disable — telemetry.ts becomes a no-op.
EXPO_PUBLIC_SENTRY_DSN=
